# ===========================================
# TRADESHARE - CONFIGURACIÓN DE ENTORNO
# ===========================================
# Copia este archivo como .env.local y completa los valores
#
# REGLA: VITE_* solo se expone al browser.
#        Variables sin prefijo VITE_ son server-side únicamente.

# ===========================================
# BROWSER (Vite expone estas al bundle del cliente)
# ===========================================

VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_APP_URL=https://tu-dominio.vercel.app
VITE_API_URL=https://tu-dominio.vercel.app/api
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_FEATURE_SIGNALS=off
# Mantener en off hasta resolver FIX-004 / AGENT_CONVEX_REPAIR_ORDER.md
VITE_SENTRY_DSN=https://examplePublicKey@o123456.ingest.sentry.io/1234567
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_YOUTUBE_API_KEY=AIzaSyAOuRFzJ157GdmOctojcYyy3Lwg61pDo0o
VITE_NVIDIA_API_KEY=your-nvidia-ngc-api-key

# ===========================================
# SERVER (Node.js / Express — NUNCA exponer al browser)
# ===========================================

# URLs del servidor (equivalente server-side de VITE_APP_URL / VITE_CONVEX_URL)
APP_URL=https://tu-dominio.vercel.app
CONVEX_URL=https://your-deployment.convex.cloud
FRONTEND_URL=https://tu-dominio.vercel.app

# Convex deployment
CONVEX_DEPLOYMENT=dev:your-deployment-id
CONVEX_SITE_URL=https://your-deployment.convex.site

# Sentry build
SENTRY_ORG=your-org
SENTRY_PROJECT=tradeportal
SENTRY_AUTH_TOKEN=sntrys_your_token_here

# Auth
AUTH_URL=https://tu-dominio.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_YEARLY=price_...
STRIPE_PRICE_ID_ELITE_MONTHLY=price_...
STRIPE_PRICE_ID_ELITE_YEARLY=price_...
STRIPE_CREATOR_PRICE_ID_MONTHLY=price_...
STRIPE_CREATOR_PRICE_ID_YEARLY=price_...

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_PLAN_BASIC=plan_xxxxxxxxxxxxxxxx
MP_PLAN_PRO=plan_xxxxxxxxxxxxxxxx
MP_PLAN_VIP=plan_xxxxxxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret

# Zenobank
ZENOBANK_API_KEY=your_zenobank_api_key
ZENOBANK_WEBHOOK_SECRET=your_zenobank_webhook_secret

# Sendgrid
SENDGRID_API_KEY=SG.xxxxxxxxxx.xxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@tu-dominio.com

# AI Providers
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-coder:free
GROQ_API_KEY=gsk_...
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=...
CEREBRAS_DEFAULT_MODEL=gpt-oss-120b

# Moonshot AI (Kimi) - https://platform.moonshot.ai
MOONSHOT_API_KEY=your_moonshot_api_key
MOONSHOT_DEFAULT_MODEL=kimi-k2-0905-preview

# JWT Secret for server-side authentication
JWT_SECRET=tradeshare_jwt_secret_change_in_production

INTERNAL_API_SHARED_KEY=change_me

# AI relay / rate limiting
AI_RATE_LIMIT_PER_MIN=60

# ===========================================
# WhatsApp Notifications (Meta Cloud API)
# ===========================================
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
NOTIFICATION_API_KEY=change_me_notifications_api_key

# Optional provider base URLs if using custom endpoints
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ImgBB (server-side image upload relay)
IMGBB_API_KEY=your_imgbb_api_key

# ElevenLabs (AI Voice - Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Fish.Audio (AI Voice - Alternative TTS con voice cloning)
FISH_AUDIO_API_KEY=your_fishaudio_api_key

# Web Push (Signal Notifications)
# Genera tus propias claves con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BEl62iUYgUivxIkv69yViEuiBIa-Ib9-SkvMeAtA3LFgDzkrxZJjSgSnfckjBJuBkr3qBUYIHBQFLXYp5Nksh8U
VAPID_PRIVATE_KEY=UUxI4O8-FbRouAevSmBQ6o18hgE4nSG3qwvJTfKc-ls
VAPID_SUBJECT=mailto:notifications@tu-dominio.com

# Instagram / Meta Integration
INSTAGRAM_APP_ID=tu_instagram_app_id
INSTAGRAM_APP_SECRET=tu_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://tu-dominio.vercel.app/api/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=tu_verify_token

# ===========================================
# NOTION - Communication & Knowledge Base
# ===========================================
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORKSPACE_NAME=TradeShare Team

# ===========================================
# DEPLOY
# ===========================================

# Convex:
npx convex deploy

# Vercel:
npx vercel --prod

# Variables en Vercel (server-side):
# vercel env add APP_URL
# vercel env add CONVEX_URL
# vercel env add FRONTEND_URL
# vercel env add MERCADOPAGO_ACCESS_TOKEN
