# ============================================
# AURORA AI - FREE API PROVIDERS
# ============================================
# Todos estos providers son 100% GRATIS
# No requieren tarjeta de crédito
# ============================================

# ============================================
# TIER 1: MEJOR CALIDAD (Totalmente gratis)
# ============================================

# Google Gemini (MEJOR OPCIÓN GRATIS)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CONTEXT=1048576

# Groq (MÁS RÁPIDO - 70B en ~0.7s)
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA/Kimi (CALIDAD OPUS)
# https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2-instruct

# ============================================
# TIER 2: CALIDAD OPUS GRATIS (Beta)
# ============================================

# DeepSeek (CALIDAD OPUS - Gratis beta)
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat-v3
DEEPSEEK_CONTEXT=128000

# ============================================
# TIER 3: BACKUP (Múltiples modelos)
# ============================================

# OpenRouter (50+ modelos, $1 credit inicial)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Fireworks AI (1M tokens/month gratis)
# https://fireworks.ai/api-keys
FIREWORKS_API_KEY=

# Together AI ($25 credit inicial)
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Cohere (100 calls/day gratis)
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ============================================
# TIER 4: LOCAL (Sin límites)
# ============================================

# Ollama Local (Requiere instalación)
# https://ollama.ai/download
OLLAMA_BASE_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen-2.5-7b
OLLAMA_CONTEXT=32000

# ============================================
# WEB SEARCH (Para research en tiempo real)
# ============================================

# Brave Search (1000 queries/month gratis)
# https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Tavily (1000 searches/month gratis)
# https://tavily.com/api/
TAVILY_API_KEY=

# ============================================
# AURORA SETTINGS
# ============================================

AURORA_PORT=4310
AURORA_MEMORY_LIMIT=500MB
AURORA_LOG_LEVEL=info

# Provider Router Settings
AURORA_PROVIDER_STRATEGY=quality_first
AURORA_AUTO_FALLBACK=true
AURORA_CACHE_RESPONSE=true
